import xml.etree.ElementTree as ET
import numpy as np
import pandas as pd
import os

def extract_timeloss_stats(tripinfo_file):
    """Extract mean and std dev of timeLoss for vehicles and pedestrians separately"""
    try:
        tree = ET.parse(tripinfo_file)
        root = tree.getroot()
        
        # Separate vehicles and pedestrians
        vehicle_time_losses = []
        pedestrian_time_losses = []
        
        # Extract from tripinfo (vehicles)
        for trip in root.findall('tripinfo'):
            time_loss = float(trip.get('timeLoss'))
            vehicle_time_losses.append(time_loss)
        
        # Extract from personinfo (pedestrians)
        for person in root.findall('personinfo'):
            # Pedestrians have walks, not trips
            for walk in person.findall('walk'):
                time_loss = float(walk.get('timeLoss'))
                pedestrian_time_losses.append(time_loss)
        
        # Calculate vehicle statistics
        vehicle_stats = {
            'vehicle_mean': np.mean(vehicle_time_losses) if vehicle_time_losses else None,
            'vehicle_std': np.std(vehicle_time_losses) if vehicle_time_losses else None,
            'vehicle_variance': np.var(vehicle_time_losses) if vehicle_time_losses else None,
            'vehicle_count': len(vehicle_time_losses)
        }
        
        # Calculate pedestrian statistics
        pedestrian_stats = {
            'pedestrian_mean': np.mean(pedestrian_time_losses) if pedestrian_time_losses else None,
            'pedestrian_std': np.std(pedestrian_time_losses) if pedestrian_time_losses else None,
            'pedestrian_variance': np.var(pedestrian_time_losses) if pedestrian_time_losses else None,
            'pedestrian_count': len(pedestrian_time_losses)
        }
        
        # Combine both
        return {**vehicle_stats, **pedestrian_stats}
        
    except Exception as e:
        print(f"Error processing {tripinfo_file}: {e}")
        return {
            'vehicle_mean': None, 'vehicle_std': None, 'vehicle_variance': None, 'vehicle_count': 0,
            'pedestrian_mean': None, 'pedestrian_std': None, 'pedestrian_variance': None, 'pedestrian_count': 0
        }

