import xml.etree.ElementTree as ET
import numpy as np
import pandas as pd
import os

def extract_timeloss_stats(tripinfo_file):
    """Extract mean and std dev of timeLoss from SUMO tripinfo file"""
    try:
        tree = ET.parse(tripinfo_file)
        root = tree.getroot()
        
        time_losses = [float(trip.get('timeLoss')) 
                    for trip in root.findall('tripinfo')]
        
        if len(time_losses) == 0:
            return {'mean': None, 'std': None, 'variance': None, 'count': 0}
        
        return {
            'mean': np.mean(time_losses),
            'std': np.std(time_losses),
            'variance': np.var(time_losses),
            'count': len(time_losses)
        }
    except Exception as e:
        print(f"Error processing {tripinfo_file}: {e}")
        return {'mean': None, 'std': None, 'variance': None, 'count': 0}

# Define all algorithms and scenarios
algorithms = ['DQN', 'A2C', 'DDPG']
scenarios = ['Normal', 'Slow', 'Jam']

# Process all combinations
all_results = {}

for algo in algorithms:
    for scenario in scenarios:
        # Construct filepath
        filepath = f'Olivarez_traci\\output_{algo}\\SP_{algo}_Unified_{scenario}_trips.xml'
        
        # Check if file exists
        if os.path.exists(filepath):
            key = f'{algo}_{scenario}'
            print(f"Processing {key}...")
            all_results[key] = extract_timeloss_stats(filepath)
        else:
            print(f"File not found: {filepath}")

# Create DataFrame
df = pd.DataFrame(all_results).T

# Reorganize for better viewing
df_pivot = df.reset_index()
df_pivot[['Algorithm', 'Scenario']] = df_pivot['index'].str.split('_', expand=True)
df_pivot = df_pivot[['Algorithm', 'Scenario', 'mean', 'std', 'count']]

print("\n=== Complete Results ===")
print(df_pivot)

# Save to CSV
df_pivot.to_csv('olivarez_all_algorithms_results.csv', index=False)
print("\nResults saved to 'olivarez_all_algorithms_results.csv'")

# Create comparison table by scenario
print("\n=== Comparison by Scenario ===")
for scenario in scenarios:
    print(f"\n{scenario} Traffic:")
    scenario_data = df_pivot[df_pivot['Scenario'] == scenario]
    print(scenario_data[['Algorithm', 'mean', 'std']].to_string(index=False))